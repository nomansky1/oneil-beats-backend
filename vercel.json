{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": {
        "maxLambdaSize": "50mb",
        "maxDuration": 60,
        "includeFiles": "public/**",
        "excludeFiles": "node_modules/ff*-static/**"
      }
    }
  ],
  "routes": [
    {
      "src": "/admin",
      "dest": "/server.js"
    },
    {
      "src": "/webhook",
      "dest": "/server.js"
    },
    {
      "src": "/(.*)",
      "dest": "/server.js"
    }
  ],
  "crons": [
    {
      "path": "/cron/publish-scheduled",
      "schedule": "0 12 * * *"
    }
  ]
}

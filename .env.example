# ─── Google API ───────────────────────────────────────────────
# Create a Service Account in Google Cloud Console
# Enable Google Drive API + Google Sheets API
# Download the JSON key and put the values below

GOOGLE_CLIENT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----\n"

# The ID of your Google Sheet (from the URL: docs.google.com/spreadsheets/d/SHEET_ID/edit)
GOOGLE_SHEET_ID=your_sheet_id_here

# The ID of your Google Drive folder where beat audio files live
GOOGLE_DRIVE_FOLDER_ID=your_drive_folder_id_here

# ─── Stripe ───────────────────────────────────────────────────
# Get these from https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Your app's public URL (used for Stripe redirect + download links)
APP_URL=https://your-app-url.com

# ─── Email (for order confirmations) ──────────────────────────
# Use Gmail App Password or SendGrid
EMAIL_FROM=oneilbeats@gmail.com
EMAIL_PASS=your_app_password_here

# ─── Server ───────────────────────────────────────────────────
PORT=3001

# ─── Cloudflare R2 (Phase 1 — additive, not active in prod) ───
# Created in Cloudflare dashboard → R2 → Manage API Tokens.
# Token needs Object Read + Write on the bucket.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
# S3 API endpoint, e.g. https://{accountId}.r2.cloudflarestorage.com
R2_ENDPOINT=
# Where files are served publicly. For production this MUST be either:
#   • A custom domain mapped to the bucket (e.g. https://cdn.oneilbeats.store), OR
#   • The bucket's managed pub-XXXXXX.r2.dev URL
# Do NOT use the S3 API endpoint here — that requires signed requests.
R2_PUBLIC_URL=

# Phase 2 cutover flag. When 'true', new uploads route to R2 instead of GCS.
# Leave 'false' until scripts/test-r2.js passes end-to-end including public read.
USE_R2_FOR_UPLOADS=false
